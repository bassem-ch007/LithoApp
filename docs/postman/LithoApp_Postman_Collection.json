{
  "info": {
    "name": "LithoApp — Full Workflow",
    "_postman_id": "a7b3c1e0-1111-4222-8333-900000000001",
    "description": "End-to-end workflow for the LithoApp microservices: Patient → Episode → Analysis Request, including the new biologist identity-search endpoint on analysis-service backed by OpenFeign to patient-service.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Patient Service",
      "item": [
        {
          "name": "Create Patient (urologist)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.environment.set('patientId', body.id);",
                  "pm.environment.set('patientDi', body.di);",
                  "pm.environment.set('patientDmi', body.dmi);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{patientServiceUrl}}/patients", "host": ["{{patientServiceUrl}}"], "path": ["patients"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"di\": \"DI{{$timestamp}}\",\n  \"dmi\": \"DMI{{$timestamp}}\",\n  \"firstName\": \"Ali\",\n  \"lastName\": \"Ben Salah\",\n  \"birthDate\": \"1985-03-14\",\n  \"gender\": \"MALE\",\n  \"height\": 178,\n  \"weight\": 82,\n  \"address\": \"Tunis\",\n  \"email\": \"ali.bensalah@example.tn\",\n  \"phone\": \"22111222\"\n}"
            }
          }
        },
        {
          "name": "Get Patient by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{patientServiceUrl}}/patients/{{patientId}}", "host": ["{{patientServiceUrl}}"], "path": ["patients", "{{patientId}}"] }
          }
        },
        {
          "name": "Get Patient by DI",
          "request": {
            "method": "GET",
            "url": { "raw": "{{patientServiceUrl}}/patients/by-di/{{patientDi}}", "host": ["{{patientServiceUrl}}"], "path": ["patients", "by-di", "{{patientDi}}"] }
          }
        },
        {
          "name": "Get Patient by DMI",
          "request": {
            "method": "GET",
            "url": { "raw": "{{patientServiceUrl}}/patients/by-dmi/{{patientDmi}}", "host": ["{{patientServiceUrl}}"], "path": ["patients", "by-dmi", "{{patientDmi}}"] }
          }
        },
        {
          "name": "Search Patients",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{patientServiceUrl}}/patients/search?di={{patientDi}}",
              "host": ["{{patientServiceUrl}}"],
              "path": ["patients", "search"],
              "query": [
                { "key": "di", "value": "{{patientDi}}" },
                { "key": "dmi", "value": "", "disabled": true },
                { "key": "name", "value": "", "disabled": true },
                { "key": "phone", "value": "", "disabled": true }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Episode Service",
      "item": [
        {
          "name": "Create Episode",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.environment.set('episodeId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{episodeServiceUrl}}/episodes", "host": ["{{episodeServiceUrl}}"], "path": ["episodes"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"openedAt\": \"2026-04-24\",\n  \"title\": \"Right kidney stone — first event\",\n  \"notes\": \"Initial lithiasis episode\",\n  \"recurrence\": false\n}"
            }
          }
        },
        {
          "name": "Get Episode by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{episodeServiceUrl}}/episodes/{{episodeId}}", "host": ["{{episodeServiceUrl}}"], "path": ["episodes", "{{episodeId}}"] }
          }
        },
        {
          "name": "List Episodes by Patient",
          "request": {
            "method": "GET",
            "url": { "raw": "{{episodeServiceUrl}}/episodes/patient/{{patientId}}", "host": ["{{episodeServiceUrl}}"], "path": ["episodes", "patient", "{{patientId}}"] }
          }
        }
      ]
    },
    {
      "name": "3. Analysis Service",
      "item": [
        {
          "name": "Create METABOLIC Analysis Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('201 Created', function () { pm.response.to.have.status(201); });",
                  "const body = pm.response.json();",
                  "pm.environment.set('analysisRequestId', body.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{analysisServiceUrl}}/api/analysis-requests", "host": ["{{analysisServiceUrl}}"], "path": ["api", "analysis-requests"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"episodeId\": {{episodeId}},\n  \"createdBy\": \"urologist-001\",\n  \"type\": \"METABOLIC\"\n}"
            }
          }
        },
        {
          "name": "Create STONE Analysis Request",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{analysisServiceUrl}}/api/analysis-requests", "host": ["{{analysisServiceUrl}}"], "path": ["api", "analysis-requests"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": {{patientId}},\n  \"episodeId\": {{episodeId}},\n  \"createdBy\": \"urologist-001\",\n  \"type\": \"STONE\"\n}"
            }
          }
        },
        {
          "name": "Get Analysis Request by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{analysisServiceUrl}}/api/analysis-requests/{{analysisRequestId}}", "host": ["{{analysisServiceUrl}}"], "path": ["api", "analysis-requests", "{{analysisRequestId}}"] }
          }
        },
        {
          "name": "List by Episode",
          "request": {
            "method": "GET",
            "url": { "raw": "{{analysisServiceUrl}}/api/analysis-requests/episode/{{episodeId}}", "host": ["{{analysisServiceUrl}}"], "path": ["api", "analysis-requests", "episode", "{{episodeId}}"] }
          }
        },
        {
          "name": "List by Patient",
          "request": {
            "method": "GET",
            "url": { "raw": "{{analysisServiceUrl}}/api/analysis-requests/patient/{{patientId}}", "host": ["{{analysisServiceUrl}}"], "path": ["api", "analysis-requests", "patient", "{{patientId}}"] }
          }
        }
      ]
    },
    {
      "name": "4. Biologist Identity Search (NEW, Feign → patient-service)",
      "item": [
        {
          "name": "Search by DI",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{analysisServiceUrl}}/api/analysis-requests/search?di={{patientDi}}",
              "host": ["{{analysisServiceUrl}}"],
              "path": ["api", "analysis-requests", "search"],
              "query": [{ "key": "di", "value": "{{patientDi}}" }]
            }
          }
        },
        {
          "name": "Search by DMI",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{analysisServiceUrl}}/api/analysis-requests/search?dmi={{patientDmi}}",
              "host": ["{{analysisServiceUrl}}"],
              "path": ["api", "analysis-requests", "search"],
              "query": [{ "key": "dmi", "value": "{{patientDmi}}" }]
            }
          }
        },
        {
          "name": "Search by Name",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{analysisServiceUrl}}/api/analysis-requests/search?name=Ali",
              "host": ["{{analysisServiceUrl}}"],
              "path": ["api", "analysis-requests", "search"],
              "query": [{ "key": "name", "value": "Ali" }]
            }
          }
        },
        {
          "name": "Search by Phone",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{analysisServiceUrl}}/api/analysis-requests/search?phone=22111222",
              "host": ["{{analysisServiceUrl}}"],
              "path": ["api", "analysis-requests", "search"],
              "query": [{ "key": "phone", "value": "22111222" }]
            }
          }
        },
        {
          "name": "Search by DI + status=CREATED",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{analysisServiceUrl}}/api/analysis-requests/search?di={{patientDi}}&status=CREATED",
              "host": ["{{analysisServiceUrl}}"],
              "path": ["api", "analysis-requests", "search"],
              "query": [
                { "key": "di", "value": "{{patientDi}}" },
                { "key": "status", "value": "CREATED" }
              ]
            }
          }
        },
        {
          "name": "Search without any param (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('400 Bad Request', function () { pm.response.to.have.status(400); });"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": { "raw": "{{analysisServiceUrl}}/api/analysis-requests/search", "host": ["{{analysisServiceUrl}}"], "path": ["api", "analysis-requests", "search"] }
          }
        }
      ]
    }
  ]
}
