FROM maven:3.9-eclipse-temurin-21-alpine AS build

WORKDIR /workspace
COPY services/episode-service/pom.xml services/episode-service/pom.xml
WORKDIR /workspace/services/episode-service
RUN mvn -B dependency:go-offline

WORKDIR /workspace
COPY services/episode-service services/episode-service
WORKDIR /workspace/services/episode-service
RUN mvn -B package -DskipTests

FROM eclipse-temurin:21-jre-alpine

RUN addgroup -S app && adduser -S app -G app
WORKDIR /app
COPY --from=build /workspace/services/episode-service/target/*.jar /app/app.jar
RUN chown -R app:app /app

USER app
EXPOSE 8085
ENTRYPOINT ["java", "-jar", "/app/app.jar"]
