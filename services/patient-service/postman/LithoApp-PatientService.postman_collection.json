{
  "info": {
    "name": "LithoApp – Patient Service",
    "description": "Complete test collection for the Patient Service microservice.\n\nBase URL is stored in the `baseUrl` collection variable (default: http://localhost:8081).\nAfter creating a patient, the `patientId` variable is set automatically by the test script so subsequent requests use it.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8081",
      "type": "string"
    },
    {
      "key": "patientId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "patientDi",
      "value": "DI-2024-001",
      "type": "string"
    },
    {
      "key": "patientDmi",
      "value": "DMI-2024-00142",
      "type": "string"
    }
  ],
  "item": [

    {
      "name": "1 – Create Patient",
      "item": [

        {
          "name": "Create patient – full payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response contains patient id', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.id).to.be.a('number');",
                  "    pm.collectionVariables.set('patientId',  String(json.id));",
                  "    pm.collectionVariables.set('patientDi',  json.di);",
                  "    pm.collectionVariables.set('patientDmi', json.dmi);",
                  "});",
                  "",
                  "pm.test('DI and DMI are returned', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.di).to.eql('DI-2024-001');",
                  "    pm.expect(json.dmi).to.eql('DMI-2024-00142');",
                  "});",
                  "",
                  "pm.test('Clinical info is structured', () => {",
                  "    const ci = pm.response.json().clinicalInfo;",
                  "    pm.expect(ci).to.be.an('object');",
                  "    pm.expect(ci.lithiasisType).to.eql('Oxalate de calcium');",
                  "});",
                  "",
                  "pm.test('Associated diseases list is present', () => {",
                  "    const diseases = pm.response.json().associatedDiseases;",
                  "    pm.expect(diseases).to.be.an('array').with.lengthOf(2);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"di\": \"DI-2024-001\",\n  \"dmi\": \"DMI-2024-00142\",\n  \"firstName\": \"Ahmed\",\n  \"lastName\": \"Benali\",\n  \"birthDate\": \"1978-06-15\",\n  \"gender\": \"MALE\",\n  \"height\": 178.0,\n  \"weight\": 82.0,\n  \"address\": \"12 Rue des Acacias, Alger\",\n  \"email\": \"ahmed.benali@example.com\",\n  \"phone\": \"+213 555 123 456\",\n  \"clinicalInfo\": {\n    \"familyHistory\": true,\n    \"personalHistory\": true,\n    \"lastEpisodeDate\": \"2023-09-10\",\n    \"lithiasisType\": \"Oxalate de calcium\",\n    \"frequentInfections\": false,\n    \"singleKidney\": false,\n    \"kidneyType\": null,\n    \"chronicRenalFailure\": true,\n    \"clearance\": 45.5\n  },\n  \"medication\": {\n    \"hasMedication\": true,\n    \"description\": \"Hydrochlorothiazide 25mg – 1 fois/jour\\nAllopurinol 100mg – 1 fois/jour\"\n  },\n  \"associatedDiseases\": [\"Hypertension artérielle\", \"Diabète type 2\"],\n  \"geneticDiseases\": [\"Hyperoxalurie primaire de type 1\"],\n  \"anatomicalAnomalies\": [\"Rein en fer à cheval\"]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            },
            "description": "Creates a patient with a full clinical profile (all sections). The test script automatically stores `patientId`, `patientDi`, and `patientDmi` as collection variables."
          }
        },

        {
          "name": "Create patient – minimal payload",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201 Created', () => {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Active defaults to true', () => {",
                  "    pm.expect(pm.response.json().active).to.be.true;",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"di\": \"DI-2024-099\",\n  \"dmi\": \"DMI-2024-00999\",\n  \"firstName\": \"Fatima\",\n  \"lastName\": \"Khelil\",\n  \"birthDate\": \"1990-04-20\",\n  \"gender\": \"FEMALE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            },
            "description": "Creates a patient with only the required fields. All optional sections (clinicalInfo, medication, lists) are omitted."
          }
        },

        {
          "name": "Create patient – duplicate DI (expect 409)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 409 Conflict', () => {",
                  "    pm.response.to.have.status(409);",
                  "});",
                  "",
                  "pm.test('Error title is Duplicate Identifier', () => {",
                  "    pm.expect(pm.response.json().title).to.eql('Duplicate Identifier');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"di\": \"DI-2024-001\",\n  \"dmi\": \"DMI-2024-99999\",\n  \"firstName\": \"Test\",\n  \"lastName\": \"Duplicate\",\n  \"birthDate\": \"1985-01-01\",\n  \"gender\": \"MALE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            },
            "description": "Attempts to create a patient with a DI that already exists. Expects 409 Conflict."
          }
        },

        {
          "name": "Create patient – validation errors (expect 400)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => {",
                  "    pm.response.to.have.status(400);",
                  "});",
                  "",
                  "pm.test('Response contains validation errors map', () => {",
                  "    pm.expect(pm.response.json().errors).to.be.an('object');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"di\": \"\",\n  \"dmi\": \"\",\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"birthDate\": \"2099-01-01\",\n  \"gender\": null,\n  \"height\": -5,\n  \"email\": \"not-an-email\",\n  \"clinicalInfo\": {\n    \"clearance\": -10\n  },\n  \"medication\": {\n    \"hasMedication\": null\n  }\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/patients",
              "host": ["{{baseUrl}}"],
              "path": ["patients"]
            },
            "description": "Sends an intentionally invalid payload to verify all validation constraints fire correctly."
          }
        }

      ]
    },

    {
      "name": "2 – Get Patient",
      "item": [

        {
          "name": "Get by ID",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 200 OK', () => {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Returned id matches requested id', () => {",
                  "    const id = parseInt(pm.collectionVariables.get('patientId'));",
                  "    pm.expect(pm.response.json().id).to.eql(id);",
                  "});",
                  "",
                  "pm.test('Full response includes all sections', () => {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.all.keys(",
                  "        'id','di','dmi','firstName','lastName','birthDate','gender',",
                  "        'active','createdAt','updatedAt',",
                  "        'clinicalInfo','medication','associatedDiseases',",
                  "        'geneticDiseases','anatomicalAnomalies'",
                  "    );",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/patients/{{patientId}}",
              "host": ["{{baseUrl}}"],
              "path": ["patients", "{{patientId}}"]
            },
            "description": "Retrieves the full patient profile by internal ID (set automatically after Create)."
