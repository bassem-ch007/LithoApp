{
  "info": {
    "name": "LithoApp — Drainage Service",
    "description": "Complete test collection for the Drainage Service REST API.\n\nBase URL : http://localhost:8084\nPort     : 8084\nDatabase : drainage_db (PostgreSQL)\n\nRun folders in order 01 → 06.\nIDs created in folder 01 are automatically saved as collection variables and reused in all subsequent folders.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },

  "variable": [
    { "key": "baseUrl",        "value": "http://localhost:8084", "type": "string" },
    { "key": "jj_id",          "value": "",                      "type": "string" },
    { "key": "ureteral_id",    "value": "",                      "type": "string" },
    { "key": "nephrostomy_id", "value": "",                      "type": "string" }
  ],

  "item": [

    {
      "name": "01 — Create Drainage",
      "description": "POST /api/drainages — happy paths and all business-rule violations.",
      "item": [

        {
          "name": "✅ Create JJ drainage — STANDARD_6F, LEFT",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/drainages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drainages"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 1,\n  \"doctorId\": 10,\n  \"drainageType\": \"JJ\",\n  \"side\": \"LEFT\",\n  \"placedAt\": \"2026-04-01\",\n  \"plannedRemovalDate\": \"2026-07-01\",\n  \"jjType\": \"STANDARD_6F\",\n  \"notes\": \"Placed after ureteroscopy for left ureteral stone.\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "const b = pm.response.json();",
                "pm.test('id is present', () => pm.expect(b.id).to.be.a('string'));",
                "pm.test('status is ACTIVE', () => pm.expect(b.status).to.eql('ACTIVE'));",
                "pm.test('drainageType is JJ', () => pm.expect(b.drainageType).to.eql('JJ'));",
                "pm.test('jjType is STANDARD_6F', () => pm.expect(b.jjType).to.eql('STANDARD_6F'));",
                "pm.test('overdue is boolean', () => pm.expect(b.overdue).to.be.a('boolean'));",
                "pm.test('no episodeId field', () => pm.expect(b.episodeId).to.be.undefined);",
                "pm.collectionVariables.set('jj_id', b.id);",
                "console.log('jj_id saved:', b.id);"
              ]
            }
          }]
        },

        {
          "name": "✅ Create URETERAL drainage — RIGHT, no plannedRemovalDate",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/drainages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drainages"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"patientId\": 2,\n  \"doctorId\": 10,\n  \"drainageType\": \"URETERAL\",\n  \"side\": \"RIGHT\",\n  \"placedAt\": \"2026-04-05\",\n  \"notes\": \"Post-operative ureteral catheter.\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('201 Created', () => pm.response.to.have.status(201));",
                "const b = pm.response.json();",
                "pm.test('drainageType is URETERAL', () => pm.expect(b.drainageType).to.eql('URETERAL'));",
                "pm.test('jjType is null', () => pm.expect(b.jjType).to.be.null);",
                "pm.test('plannedRemovalDate is null', () => pm.expect(b.plannedRemovalDate).to.be.null);",
                "pm.collectionVariables.set('ureteral_id', b.id);",
                "console.log('ureteral_id saved:', b.id);"
              ]
            }
          }]
        },

