    {
      "name": "02 — Get Drainage by ID",
      "description": "GET /api/drainages/{id}",
      "item": [

        {
          "name": "✅ Get JJ drainage by ID",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/drainages/{{jj_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drainages", "{{jj_id}}"]
