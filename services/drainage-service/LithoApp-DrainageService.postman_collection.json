    {
      "name": "03 — List & Filter Drainages",
      "description": "GET /api/drainages — available filters: patientId, drainageType, status, overdue",
      "item": [

        {
          "name": "✅ Get all (no filter)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/drainages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drainages"]
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('response is array', () => pm.expect(pm.response.json()).to.be.an('array'));",
                "pm.test('at least 4 records created', () => pm.expect(pm.response.json().length).to.be.at.least(4));"
              ]
            }
          }]
        },

        {
          "name": "✅ Filter by patientId=1",
