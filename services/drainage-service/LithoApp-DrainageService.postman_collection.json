                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "const b = pm.response.json();",
                "pm.test('id matches', () => pm.expect(b.id).to.eql(pm.collectionVariables.get('jj_id')));",
                "pm.test('drainageType is JJ', () => pm.expect(b.drainageType).to.eql('JJ'));",
                "pm.test('overdue field present', () => pm.expect(b).to.have.property('overdue'));",
