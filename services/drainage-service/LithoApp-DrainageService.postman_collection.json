    {
      "name": "04 — Update Drainage",
      "description": "PUT /api/drainages/{id} — only plannedRemovalDate and notes can be updated, only when ACTIVE.",
      "item": [

        {
          "name": "✅ Update plannedRemovalDate",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/drainages/{{jj_id}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "drainages", "{{jj_id}}"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"plannedRemovalDate\": \"2026-09-15\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('200 OK', () => pm.response.to.have.status(200));",
                "pm.test('plannedRemovalDate updated', () => pm.expect(pm.response.json().plannedRemovalDate).to.eql('2026-09-15'));"
              ]
            }
          }]
        },

        {
          "name": "✅ Update notes only",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": {
              "raw": "{{baseUrl}}/api/drainages/{{ureteral_id}}",
