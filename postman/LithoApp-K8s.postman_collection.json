{
  "info": {
    "_postman_id": "6c616e0d-4cb5-4a1e-8e77-lithoappk8s",
    "name": "LithoApp K8s Gateway",
    "description": "Gateway-only LithoApp Kubernetes collection. Uses Keycloak real-user tokens only; no client_credentials requests are included.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [
      { "key": "token", "value": "{{access_token}}", "type": "string" }
    ]
  },
  "item": [
    {
      "name": "00 - Auth / Keycloak",
      "item": [
        {
          "name": "Get Token (Password Grant) - Urologist",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "username", "value": "{{urologist_username}}", "type": "text" },
                { "key": "password", "value": "{{urologist_password}}", "type": "text" }
              ]
            },
            "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('token endpoint returns 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.test('access token is present', function () { pm.expect(json.access_token).to.be.a('string').and.not.empty; });",
            "pm.environment.set('access_token', json.access_token);",
            "if (json.refresh_token) pm.environment.set('refresh_token', json.refresh_token);"
          ] } }]
        },
        {
          "name": "Get Token (Password Grant) - Biologist",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "username", "value": "{{biologist_username}}", "type": "text" },
                { "key": "password", "value": "{{biologist_password}}", "type": "text" }
              ]
            },
            "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('token endpoint returns 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.environment.set('access_token', json.access_token);",
            "if (json.refresh_token) pm.environment.set('refresh_token', json.refresh_token);"
          ] } }]
        },
        {
          "name": "Get Token (Password Grant) - Admin",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "password", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "username", "value": "{{admin_username}}", "type": "text" },
                { "key": "password", "value": "{{admin_password}}", "type": "text" }
              ]
            },
            "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('token endpoint returns 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.environment.set('access_token', json.access_token);",
            "if (json.refresh_token) pm.environment.set('refresh_token', json.refresh_token);"
          ] } }]
        },
        {
          "name": "Refresh Token",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "refresh_token", "type": "text" },
                { "key": "client_id", "value": "{{client_id}}", "type": "text" },
                { "key": "refresh_token", "value": "{{refresh_token}}", "type": "text" }
              ]
            },
            "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token"
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": [
            "pm.test('token endpoint returns 200', function () { pm.response.to.have.status(200); });",
            "const json = pm.response.json();",
            "pm.environment.set('access_token', json.access_token);",
            "if (json.refresh_token) pm.environment.set('refresh_token', json.refresh_token);"
          ] } }]
        },
        {
          "name": "OAuth2 Authorization Code with PKCE - Configuration Notes",
          "request": {
            "auth": { "type": "noauth" },
            "method": "GET",
            "header": [],
            "url": "{{keycloak_base_url}}/realms/{{realm}}/.well-known/openid-configuration",
            "description": "Use Postman Authorization tab: OAuth 2.0, Authorization Code with PKCE, S256, scope openid profile email. Auth URL {{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/auth; token URL {{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token; client_id {{client_id}}. Login as a real user."
          },
          "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }]
        }
      ]
    },
    {
      "name": "01 - Patient Service",
      "item": [
        {
          "name": "Create patient",
          "event": [
            { "listen": "prerequest", "script": { "type": "text/javascript", "exec": [
              "const suffix = Date.now().toString();",
              "pm.environment.set('run_suffix', suffix);",
              "pm.environment.set('patient_di', 'DI-' + suffix);",
              "pm.environment.set('patient_dmi', 'DMI-' + suffix);"
            ] } },
            { "listen": "test", "script": { "type": "text/javascript", "exec": [
              "pm.test('status is 201', function () { pm.response.to.have.status(201); });",
              "const json = pm.response.json();",
              "pm.test('patient id is present', function () { pm.expect(json.id).to.exist; });",
              "pm.environment.set('patient_id', json.id);",
              "pm.test('patient DI/DMI match request', function () { pm.expect(json.di).to.eql(pm.environment.get('patient_di')); pm.expect(json.dmi).to.eql(pm.environment.get('patient_dmi')); });"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }],
            "url": "{{gateway_base_url}}/patients",
            "body": { "mode": "raw", "raw": "{\n  \"di\": \"{{patient_di}}\",\n  \"dmi\": \"{{patient_dmi}}\",\n  \"firstName\": \"Postman\",\n  \"lastName\": \"Urology\",\n  \"birthDate\": \"1980-01-15\",\n  \"gender\": \"MALE\",\n  \"height\": 178.5,\n  \"weight\": 82.3,\n  \"address\": \"1 Test Clinic Road\",\n  \"email\": \"postman.patient@example.com\",\n  \"phone\": \"+21620000000\",\n  \"clinicalInfo\": {\n    \"familyHistory\": true,\n    \"personalHistory\": false,\n    \"lastEpisodeDate\": \"2025-09-12\",\n    \"lithiasisType\": \"CALCIUM_OXALATE\",\n    \"frequentInfections\": false,\n    \"singleKidney\": false,\n    \"kidneyType\": \"ANATOMICAL\",\n    \"chronicRenalFailure\": false,\n    \"clearance\": 91.2\n  },\n  \"medication\": { \"hasMedication\": true, \"description\": \"Thiazide\" },\n  \"associatedDiseases\": [\"hypertension\"],\n  \"geneticDiseases\": [],\n  \"anatomicalAnomalies\": []\n}", "options": { "raw": { "language": "json" } } }
          }
        },
        { "name": "Get patients (search/list)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/patients/search?size=20&sort=lastName" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Search patients by DI", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/patients/search?di={{patient_di}}&size=20" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get patient by ID", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/patients/{{patient_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });", "pm.test('patient id matches', function () { pm.expect(String(pm.response.json().id)).to.eql(String(pm.environment.get('patient_id'))); });"] } }] },
        { "name": "Get patient by DI", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/patients/by-di/{{patient_di}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get patient by DMI", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/patients/by-dmi/{{patient_dmi}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Update patient", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/patients/{{patient_id}}", "body": { "mode": "raw", "raw": "{\n  \"firstName\": \"PostmanUpdated\",\n  \"phone\": \"+21621111111\",\n  \"clinicalInfo\": { \"clearance\": 95.1 },\n  \"medication\": { \"hasMedication\": false, \"description\": \"\" }\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Delete patient (only if no linked episodes)", "request": { "method": "DELETE", "header": [], "url": "{{gateway_base_url}}/patients/{{patient_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 204 or 409', function () { pm.expect([204,409]).to.include(pm.response.code); });"] } }] },
        { "name": "Negative - duplicate DI/DMI", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/patients", "body": { "mode": "raw", "raw": "{\n  \"di\": \"{{patient_di}}\",\n  \"dmi\": \"{{patient_dmi}}\",\n  \"firstName\": \"Duplicate\",\n  \"lastName\": \"Patient\",\n  \"birthDate\": \"1980-01-15\",\n  \"gender\": \"MALE\",\n  \"medication\": { \"hasMedication\": false }\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 409', function () { pm.response.to.have.status(409); });"] } }] },
        { "name": "Negative - missing required fields", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/patients", "body": { "mode": "raw", "raw": "{\n  \"di\": \"\",\n  \"dmi\": \"\",\n  \"firstName\": \"\",\n  \"lastName\": \"\",\n  \"birthDate\": null,\n  \"gender\": null\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 400', function () { pm.response.to.have.status(400); });"] } }] }
      ]
    },
    {
      "name": "02 - Episode Service",
      "item": [
        { "name": "Create episode", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes", "body": { "mode": "raw", "raw": "{\n  \"patientId\": {{patient_id}},\n  \"openedAt\": \"2026-04-27\",\n  \"title\": \"Postman stone episode\",\n  \"notes\": \"Created through gateway collection\",\n  \"recurrence\": false\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 201', function () { pm.response.to.have.status(201); });", "pm.environment.set('episode_id', pm.response.json().id);"] } }] },
        { "name": "Get episodes by patient", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes/patient/{{patient_id}}?size=10&sort=openedAt" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get active episodes by patient", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes/patient/{{patient_id}}?status=ACTIVE&size=10&sort=openedAt" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get episode by ID", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes/{{episode_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Has episodes for patient", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes/patient/{{patient_id}}/exists" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Close episode", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes/{{episode_id}}", "body": { "mode": "raw", "raw": "{\n  \"status\": \"CLOSED\",\n  \"notes\": \"Closed by Postman workflow\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });", "pm.test('episode is closed', function () { pm.expect(pm.response.json().status).to.eql('CLOSED'); });"] } }] },
        { "name": "Negative - invalid patient", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes", "body": { "mode": "raw", "raw": "{\n  \"patientId\": 999999999,\n  \"openedAt\": \"2026-04-27\",\n  \"title\": \"Invalid patient episode\",\n  \"notes\": \"Expect 404 from patient validation\",\n  \"recurrence\": false\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 404', function () { pm.response.to.have.status(404); });"] } }] }
      ]
    },
    {
      "name": "03 - Analysis Service",
      "item": [
        { "name": "Create METABOLIC analysis", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests", "body": { "mode": "raw", "raw": "{\n  \"patientId\": {{patient_id}},\n  \"episodeId\": {{episode_id}},\n  \"createdBy\": \"{{urologist_username}}\",\n  \"type\": \"METABOLIC\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 201', function () { pm.response.to.have.status(201); });", "const json = pm.response.json();", "pm.environment.set('analysis_request_id', json.id);", "pm.test('metabolic request created', function () { pm.expect(json.type).to.eql('METABOLIC'); pm.expect(json.status).to.eql('CREATED'); });"] } }] },
        { "name": "Create STONE analysis", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests", "body": { "mode": "raw", "raw": "{\n  \"patientId\": {{patient_id}},\n  \"episodeId\": {{episode_id}},\n  \"createdBy\": \"{{urologist_username}}\",\n  \"type\": \"STONE\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 201', function () { pm.response.to.have.status(201); });", "pm.environment.set('stone_analysis_request_id', pm.response.json().id);"] } }] },
        { "name": "Get analysis list", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests?episodeId={{episode_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get analysis by ID", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get analysis by patient", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/patient/{{patient_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Search analysis by patient identity", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/search?di={{patient_di}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Start analysis - automatic by first contribution (read status)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}", "description": "No explicit start endpoint exists in AnalysisRequestController. Uploading a metabolic PDF or PATCHing stone data auto-transitions CREATED to IN_PROGRESS." }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Upload metabolic PDF (multipart/form-data)", "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/metabolic/documents/BLOOD_TEST", "description": "Field name must be file. Select a local PDF manually in Postman before sending. biologistId is a text form field.", "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }, { "key": "biologistId", "value": "{{biologist_username}}", "type": "text" }] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });", "pm.environment.set('metabolic_document_id', pm.response.json().id);"] } }] },
        { "name": "Get metabolic result", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/metabolic" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Download metabolic PDF", "request": { "method": "GET", "header": [], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/metabolic/documents/BLOOD_TEST/download" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200 or 404', function () { pm.expect([200,404]).to.include(pm.response.code); });"] } }] },
        { "name": "Download metabolic PDF version", "request": { "method": "GET", "header": [], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/metabolic/documents/BLOOD_TEST/versions/1/download" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200 or 404', function () { pm.expect([200,404]).to.include(pm.response.code); });"] } }] },
        { "name": "Update stone analysis", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{stone_analysis_request_id}}/stone", "body": { "mode": "raw", "raw": "{\n  \"modifiedBy\": \"{{biologist_username}}\",\n  \"morphSize\": \"8 mm\",\n  \"morphSurface\": \"spiculated\",\n  \"morphColor\": \"brown\",\n  \"spectroSurface\": \"calcium oxalate\",\n  \"finalStoneType\": \"Whewellite\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get stone analysis", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{stone_analysis_request_id}}/stone" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Complete metabolic analysis", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/complete", "body": { "mode": "raw", "raw": "{\n  \"completedBy\": \"{{biologist_username}}\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });", "pm.test('analysis completed', function () { pm.expect(pm.response.json().status).to.eql('COMPLETED'); });"] } }] },
        { "name": "Complete stone analysis", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{stone_analysis_request_id}}/complete", "body": { "mode": "raw", "raw": "{\n  \"completedBy\": \"{{biologist_username}}\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get analysis audit log", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/audit" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Negative - complete without result", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id_without_result}}/complete", "description": "Create a fresh analysis first or set analysis_request_id_without_result manually to a request still in CREATED status.", "body": { "mode": "raw", "raw": "{\n  \"completedBy\": \"{{biologist_username}}\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 400 or 404', function () { pm.expect([400,404]).to.include(pm.response.code); });"] } }] },
        { "name": "Negative - add result before start (not applicable in code)", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{stone_analysis_request_id}}/stone", "description": "There is no explicit start endpoint. First result contribution is valid and auto-starts the request, so this request documents actual behavior.", "body": { "mode": "raw", "raw": "{\n  \"modifiedBy\": \"{{biologist_username}}\",\n  \"morphSize\": \"before explicit start\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('actual code returns 200 unless already completed', function () { pm.expect([200,400]).to.include(pm.response.code); });"] } }] },
        { "name": "Negative - invalid patient/episode mismatch", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests", "body": { "mode": "raw", "raw": "{\n  \"patientId\": 999999999,\n  \"episodeId\": {{episode_id}},\n  \"createdBy\": \"{{urologist_username}}\",\n  \"type\": \"METABOLIC\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 400 or 404', function () { pm.expect([400,404]).to.include(pm.response.code); });"] } }] }
      ]
    },
    {
      "name": "04 - Drainage Service",
      "item": [
        { "name": "Create drainage", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }, { "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages", "body": { "mode": "raw", "raw": "{\n  \"episodeId\": {{episode_id}},\n  \"patientId\": {{patient_id}},\n  \"doctorId\": 1,\n  \"drainageType\": \"JJ\",\n  \"side\": \"LEFT\",\n  \"placedAt\": \"2026-04-27\",\n  \"plannedRemovalDate\": \"2026-05-27\",\n  \"jjType\": \"STANDARD_6F\",\n  \"notes\": \"Postman test drainage\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 201', function () { pm.response.to.have.status(201); });", "pm.environment.set('drainage_id', pm.response.json().id);"] } }] },
        { "name": "Get drainages", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages?episodeId={{episode_id}}&patientId={{patient_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get drainage by ID", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages/{{drainage_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get drainages by episode", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages/episode/{{episode_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Get drainages by patient", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages/patient/{{patient_id}}" }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Update drainage", "request": { "method": "PUT", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages/{{drainage_id}}", "body": { "mode": "raw", "raw": "{\n  \"plannedRemovalDate\": \"2026-06-10\",\n  \"notes\": \"Updated by Postman\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Remove drainage", "request": { "method": "PATCH", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages/{{drainage_id}}/remove", "body": { "mode": "raw", "raw": "{\n  \"removedAt\": \"2026-05-10\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('status is 200', function () { pm.response.to.have.status(200); });"] } }] },
        { "name": "Negative - duplicate active drainage", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages", "description": "Run immediately after Create drainage and before Remove drainage to validate duplicate ACTIVE drainage detection.", "body": { "mode": "raw", "raw": "{\n  \"episodeId\": {{episode_id}},\n  \"patientId\": {{patient_id}},\n  \"doctorId\": 1,\n  \"drainageType\": \"JJ\",\n  \"side\": \"LEFT\",\n  \"placedAt\": \"2026-04-27\",\n  \"jjType\": \"STANDARD_6F\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 409', function () { pm.response.to.have.status(409); });"] } }] },
        { "name": "Negative - patient/episode mismatch", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages", "body": { "mode": "raw", "raw": "{\n  \"episodeId\": {{episode_id}},\n  \"patientId\": 999999999,\n  \"doctorId\": 1,\n  \"drainageType\": \"JJ\",\n  \"side\": \"LEFT\",\n  \"placedAt\": \"2026-04-27\",\n  \"jjType\": \"STANDARD_6F\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.test('negative case returns 400 or 404', function () { pm.expect([400,404]).to.include(pm.response.code); });"] } }] }
      ]
    },
    {
      "name": "05 - Full Medical Workflow",
      "item": [
        { "name": "01 Login as urologist", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }], "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token", "body": { "mode": "urlencoded", "urlencoded": [{ "key": "grant_type", "value": "password", "type": "text" }, { "key": "client_id", "value": "{{client_id}}", "type": "text" }, { "key": "username", "value": "{{urologist_username}}", "type": "text" }, { "key": "password", "value": "{{urologist_password}}", "type": "text" }] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "pm.environment.set('access_token', json.access_token);", "if (json.refresh_token) pm.environment.set('refresh_token', json.refresh_token);"] } }] },
        { "name": "02 Create patient", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/patients", "body": { "mode": "raw", "raw": "{\n  \"di\": \"{{patient_di}}\",\n  \"dmi\": \"{{patient_dmi}}\",\n  \"firstName\": \"Workflow\",\n  \"lastName\": \"Patient\",\n  \"birthDate\": \"1980-01-15\",\n  \"gender\": \"MALE\",\n  \"medication\": { \"hasMedication\": false }\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "prerequest", "script": { "type": "text/javascript", "exec": ["const suffix = Date.now().toString();", "pm.environment.set('patient_di', 'DI-' + suffix);", "pm.environment.set('patient_dmi', 'DMI-' + suffix);"] } }, { "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.environment.set('patient_id', pm.response.json().id);"] } }] },
        { "name": "03 Create episode", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/episodes", "body": { "mode": "raw", "raw": "{\n  \"patientId\": {{patient_id}},\n  \"openedAt\": \"2026-04-27\",\n  \"title\": \"Workflow episode\",\n  \"recurrence\": false\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.environment.set('episode_id', pm.response.json().id);"] } }] },
        { "name": "04 Create analysis request", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests", "body": { "mode": "raw", "raw": "{\n  \"patientId\": {{patient_id}},\n  \"episodeId\": {{episode_id}},\n  \"createdBy\": \"{{urologist_username}}\",\n  \"type\": \"METABOLIC\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.environment.set('analysis_request_id', pm.response.json().id);"] } }] },
        { "name": "05 Login as biologist", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }], "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token", "body": { "mode": "urlencoded", "urlencoded": [{ "key": "grant_type", "value": "password", "type": "text" }, { "key": "client_id", "value": "{{client_id}}", "type": "text" }, { "key": "username", "value": "{{biologist_username}}", "type": "text" }, { "key": "password", "value": "{{biologist_password}}", "type": "text" }] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "pm.environment.set('access_token', json.access_token);"] } }] },
        { "name": "06 Start analysis (automatic on first contribution)", "request": { "method": "GET", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}", "description": "No explicit start endpoint exists. Step 07 performs the auto-transition by uploading a PDF." } },
        { "name": "07 Upload PDF", "request": { "method": "POST", "header": [{ "key": "Accept", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/metabolic/documents/BLOOD_TEST", "description": "Select a local PDF manually in Postman before running this step.", "body": { "mode": "formdata", "formdata": [{ "key": "file", "type": "file", "src": "" }, { "key": "biologistId", "value": "{{biologist_username}}", "type": "text" }] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "pm.environment.set('metabolic_document_id', pm.response.json().id);"] } }] },
        { "name": "08 Complete analysis", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/analysis-requests/{{analysis_request_id}}/complete", "body": { "mode": "raw", "raw": "{ \"completedBy\": \"{{biologist_username}}\" }", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(200);", "pm.expect(pm.response.json().status).to.eql('COMPLETED');"] } }] },
        { "name": "09 Login as urologist", "request": { "auth": { "type": "noauth" }, "method": "POST", "header": [{ "key": "Content-Type", "value": "application/x-www-form-urlencoded" }], "url": "{{keycloak_base_url}}/realms/{{realm}}/protocol/openid-connect/token", "body": { "mode": "urlencoded", "urlencoded": [{ "key": "grant_type", "value": "password", "type": "text" }, { "key": "client_id", "value": "{{client_id}}", "type": "text" }, { "key": "username", "value": "{{urologist_username}}", "type": "text" }, { "key": "password", "value": "{{urologist_password}}", "type": "text" }] } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["const json = pm.response.json();", "pm.environment.set('access_token', json.access_token);"] } }] },
        { "name": "10 Create drainage", "request": { "method": "POST", "header": [{ "key": "Content-Type", "value": "application/json" }], "url": "{{gateway_base_url}}/api/drainages", "body": { "mode": "raw", "raw": "{\n  \"episodeId\": {{episode_id}},\n  \"patientId\": {{patient_id}},\n  \"doctorId\": 1,\n  \"drainageType\": \"JJ\",\n  \"side\": \"LEFT\",\n  \"placedAt\": \"2026-04-27\",\n  \"plannedRemovalDate\": \"2026-05-27\",\n  \"jjType\": \"STANDARD_6F\",\n  \"notes\": \"Workflow drainage\"\n}", "options": { "raw": { "language": "json" } } } }, "event": [{ "listen": "test", "script": { "type": "text/javascript", "exec": ["pm.response.to.have.status(201);", "pm.environment.set('drainage_id', pm.response.json().id);"] } }] }
      ]
    }
  ]
}
